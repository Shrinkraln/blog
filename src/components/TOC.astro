<!-- 文章标题提纲索引侧栏 -->
<nav class="toc-sidebar" id="toc-sidebar">
  <div class="toc-header">
    <span class="toc-title">📑 目录</span>
  </div>
  <ul id="toc-list" class="toc-list"></ul>
</nav>

<script>
  function buildTOC() {
    const article = document.querySelector('.prose');
    const tocSidebar = document.getElementById('toc-sidebar');
    const tocList = document.getElementById('toc-list');
    if (!article || !tocList) return;

    const headings = article.querySelectorAll('h1, h2, h3, h4');
    if (headings.length < 2) {
      // 少于两个标题时不显示目录
      tocSidebar?.classList.add('toc-hidden');
      return;
    }

    // 给每个标题加 id
    headings.forEach((h, i) => {
      if (!h.id) {
        h.id = `heading-${i}`;
      }
    });

    // 构建目录树：通用层级嵌套
    const stack: HTMLLIElement[] = [];
    headings.forEach((h) => {
      const level = parseInt(h.tagName.charAt(1)); // 1~4
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      a.className = `toc-link toc-h${level}`;

      // 点击平滑滚动
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(h.id);
        if (target) {
          const top = target.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: 'smooth' });
          history.replaceState(null, '', `#${h.id}`);
        }
      });

      li.appendChild(a);

      // 弹出栈中层级 >= 当前层级的项，找到正确的父级
      while (stack.length > 0) {
        const topLevel = parseInt(
          (stack[stack.length - 1] as HTMLElement).dataset.level ?? '0'
        );
        if (topLevel < level) break;
        stack.pop();
      }

      if (stack.length === 0) {
        // 顶层，直接追加到根列表
        tocList.appendChild(li);
      } else {
        // 作为子级，放入栈顶元素的嵌套列表
        const parent = stack[stack.length - 1];
        let subUl = parent.querySelector('ul');
        if (!subUl) {
          subUl = document.createElement('ul');
          subUl.className = 'toc-sub';
          parent.appendChild(subUl);
        }
        subUl.appendChild(li);
      }

      (li as HTMLElement).dataset.level = String(level);
      stack.push(li);
    });

    // IntersectionObserver 追踪当前可见标题
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = tocList.querySelector(`a[href="#${id}"]`);
          if (link) {
            link.classList.toggle('toc-active', entry.isIntersecting);
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  // 页面加载完成后构建
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', buildTOC);
  } else {
    buildTOC();
  }
</script>
