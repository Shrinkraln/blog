---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getGrouped } from '../../lib/notes';
import { url } from '../../consts';

const groups = await getGrouped();
---

<BaseLayout title="文章目录" description="按主题与系列整理的全部笔记">
  <section class="container">
    <h1 style="margin-top:32px">文章目录</h1>

    {
      groups.map((group) => (
        <details class="cat-block cat-collapse" id={group.slug} open>
          <summary class="cat-summary">
            <h2>{group.category}</h2>
            <span class="cat-toggle-icon"></span>
          </summary>

          {group.series.map((s) => (
            <details class="series-group series-collapse" open>
              <summary class="series-summary">
                📚 {s.name}
                <span class="series-count">({s.notes.length} 篇)</span>
              </summary>
              <ol class="series-list">
                {s.notes.map((n) => (
                  <li>
                    <a href={url(`/blog/${n.slug}/`)}>{n.title}</a>
                    {n.date && (
                      <span class="post-meta">
                        <FormattedDate date={n.date} />
                      </span>
                    )}
                  </li>
                ))}
              </ol>
            </details>
          ))}

          {group.loose.length > 0 && (
            <ul class="post-list">
              {group.loose.map((n) => (
                <li>
                  <h2 style="font-size:1.15rem">
                    <a href={url(`/blog/${n.slug}/`)}>{n.title}</a>
                  </h2>
                  <p class="post-meta">
                    {n.date && <FormattedDate date={n.date} />}
                    {n.tags.map((t) => (
                      <span class="tag">#{t}</span>
                    ))}
                  </p>
                  {n.description && <p class="post-desc">{n.description}</p>}
                </li>
              ))}
            </ul>
          )}
        </details>
      ))
    }
  </section>
</BaseLayout>

<script>
  // 展开/折叠时更新图标状态
  document.querySelectorAll('.cat-collapse').forEach((el) => {
    el.addEventListener('toggle', () => {
      el.classList.toggle('cat-open', (el as HTMLDetailsElement).open);
    });
  });
  document.querySelectorAll('.series-collapse').forEach((el) => {
    el.addEventListener('toggle', () => {
      el.classList.toggle('series-open', (el as HTMLDetailsElement).open);
    });
  });
</script>
