---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getGrouped, getRecent } from '../lib/notes';
import { SITE_DESCRIPTION, url } from '../consts';

const groups = await getGrouped();
const recent = await getRecent(6);

function countNotes(g: (typeof groups)[number]) {
  return g.loose.length + g.series.reduce((sum, s) => sum + s.notes.length, 0);
}
---

<BaseLayout>
  <section class="hero container">
    <h1>👋 你好，欢迎来到我的博客</h1>
    <p>{SITE_DESCRIPTION}</p>
  </section>

  <section class="container">
    <h2>主题</h2>
    <div class="cat-cards">
      {
        groups.map((g) => (
          <a class="cat-card" href={url(`/blog#${g.slug}`)}>
            <span class="cat-name">{g.category}</span>
            <span class="cat-count">{countNotes(g)} 篇</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container">
    <h2>最近更新</h2>
    <ul class="post-list">
      {
        recent.map((n) => (
          <li>
            <h2 style="font-size:1.15rem">
              <a href={url(`/blog/${n.slug}/`)}>{n.title}</a>
            </h2>
            <p class="post-meta">
              <span class="tag">{n.category}</span>
              {n.series && <span class="tag">系列 · {n.series}</span>}
              {n.date && <FormattedDate date={n.date} />}
            </p>
          </li>
        ))
      }
    </ul>
    <p style="margin-top:20px"><a href={url('/blog')}>查看全部文章目录 →</a></p>
  </section>
</BaseLayout>
